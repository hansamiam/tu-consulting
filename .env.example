# Frontend env — copy to .env (cloud) or .env.local (local dev).
# Vite loads .env.local at higher priority than .env, so for local
# development just create .env.local with the LOCAL block below and
# leave .env pointing at cloud.
#
# Only the *publishable* (anon) key belongs here — it is safe for the
# browser. Never put the service-role key in a VITE_ var.

# ─── CLOUD (production project) ──────────────────────────────────────
VITE_SUPABASE_PROJECT_ID="bsfldtpemfxhnkdzccib"
VITE_SUPABASE_URL="https://bsfldtpemfxhnkdzccib.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<cloud publishable / anon key>"

# ─── LOCAL (supabase start) — put this block in .env.local instead ───
# Run `bash scripts/local-db.sh` first. The local anon key below is the
# fixed well-known key the local Supabase stack always issues; if your
# CLI prints a different one, use what `supabase start` shows.
#
# VITE_SUPABASE_PROJECT_ID="local"
# VITE_SUPABASE_URL="http://127.0.0.1:54321"
# VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
